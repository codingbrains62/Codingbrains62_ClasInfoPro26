<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= subject || "ClasInfo Pro" %></title>
</head>
<body style="margin:0; padding:0; background:#FAFAFA; font-family: Arial, sans-serif;">

  <div style="max-width:600px; margin:0 auto; background:#ffffff; border-radius:6px;">

    <!-- Header -->
    <div style="padding:25px 0; text-align:center;">
      <img 
        src="https://s3.amazonaws.com/clastrak-email-assets/logo.png"
        alt="CLAS Logo"
        style="height:50px;"
      />
    </div>

    <!-- Body -->
    <div style="padding:20px;">
      <%- body %>
    </div>

    <!-- Footer -->
    <div style="background:#f4f4f4; padding:15px; text-align:center;">
      <p style="font-size:12px; color:#999;">
        Copyright © <%= new Date().getFullYear() %> ClasInfo Pro.
      </p>
    </div>

  </div>

</body>
</html>
